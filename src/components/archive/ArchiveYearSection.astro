---
import type { ArchiveYear } from "../../lib/archive";
import ArchiveMonthSection from "./ArchiveMonthSection.astro";

interface Props {
  group: ArchiveYear;
}

const { group } = Astro.props as Props;
const { year, total, months } = group;
---

<section
  class="grid gap-6 border-t border-zinc-200/80 pt-8 lg:grid-cols-[8rem_minmax(0,1fr)] lg:gap-12"
>
  <div class="lg:sticky lg:top-28 lg:self-start">
    <h2 class="text-4xl font-black tracking-tight text-zinc-950 sm:text-5xl">
      {year}
    </h2>
    <p class="mt-3 text-sm text-zinc-500">{total} 篇文章</p>
  </div>

  <div class="space-y-10">
    {months.map((monthGroup) => <ArchiveMonthSection group={monthGroup} />)}
  </div>
</section>
