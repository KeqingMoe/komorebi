---
import NavBar from "./NavBar.astro";
---

<header
  sticky
  bg-base="100/90"
  border="b base-content/10"
  print:hidden
  top-0
  z-50
>
  <div mx-auto max-w-6xl px="4 sm:6" flex items-center justify-between h-14>
    <a href="/">
      <h1
        text="lg transparent"
        bg="clip-text linear-to-r"
        font-bold
        from-blue
        to-red
      >
        木漏れ日
      </h1>
    </a>

    <div items-center gap-6>
      <NavBar />
    </div>
  </div>
</header>
