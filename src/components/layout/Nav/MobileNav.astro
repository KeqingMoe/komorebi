---
interface NavLink {
  href: string;
  label: string;
  isActive: boolean;
}

interface Props {
  navLinks: NavLink[];
}

const { navLinks } = Astro.props as Props;
---

<div class="relative sm:hidden" data-mobile-menu>
  <button
    type="button"
    aria-label="切换导航菜单"
    aria-expanded="false"
    class="mobile-menu-toggle flex h-9 w-9 cursor-pointer list-none items-center justify-center text-zinc-700 transition hover:text-zinc-950 [&::-webkit-details-marker]:hidden"
  >
    <span class="mobile-menu-lines" aria-hidden="true">
      <span class="mobile-menu-line"></span>
      <span class="mobile-menu-line"></span>
      <span class="mobile-menu-line"></span>
    </span>
  </button>

  <nav
    aria-label="移动端主导航"
    class="mobile-nav-panel absolute right-0 top-full z-20 mt-2 w-40 origin-top-right rounded-2xl border border-zinc-200/80 bg-white/92 p-2 text-sm font-medium text-zinc-600 shadow-lg shadow-rose-100/25 backdrop-blur-md"
  >
    {
      navLinks.map(({ href, label, isActive }) => (
        <a
          href={href}
          aria-current={isActive ? "page" : undefined}
          class:list={[
            "block rounded-xl px-3 py-2 transition hover:bg-zinc-50 hover:text-zinc-950",
            isActive && "bg-zinc-950/5 text-zinc-950",
          ]}
        >
          {label}
        </a>
      ))
    }
  </nav>
</div>

<style>
  .mobile-menu-toggle {
    -webkit-tap-highlight-color: transparent;
  }

  .mobile-menu-lines {
    position: relative;
    display: inline-flex;
    width: 1.125rem;
    height: 0.875rem;
  }

  .mobile-menu-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 180ms ease,
      opacity 140ms ease,
      top 180ms ease;
  }

  .mobile-menu-line:nth-child(1) {
    top: 0;
  }

  .mobile-menu-line:nth-child(2) {
    top: calc(50% - 0.75px);
  }

  .mobile-menu-line:nth-child(3) {
    top: calc(100% - 1.5px);
  }

  [data-mobile-menu][data-open="true"] .mobile-menu-line:nth-child(1) {
    top: calc(50% - 0.75px);
    transform: rotate(45deg);
  }

  [data-mobile-menu][data-open="true"] .mobile-menu-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.2);
  }

  [data-mobile-menu][data-open="true"] .mobile-menu-line:nth-child(3) {
    top: calc(50% - 0.75px);
    transform: rotate(-45deg);
  }

  .mobile-nav-panel {
    pointer-events: none;
    transform: translateY(-0.25rem) scale(0.96);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 220ms;
  }

  [data-mobile-menu][data-open="true"] .mobile-nav-panel {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    transition:
      opacity 180ms ease,
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 0s;
  }
</style>

<script is:inline data-astro-rerun>
  for (const root of document.querySelectorAll("[data-mobile-menu]")) {
    if (root.dataset.bound === "true") continue;
    root.dataset.bound = "true";

    const button = root.querySelector("button");
    const panel = root.querySelector("nav");

    if (!(button instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) continue;

    const setOpen = (open) => {
      root.dataset.open = open ? "true" : "false";
      button.setAttribute("aria-expanded", open ? "true" : "false");
    };

    setOpen(false);

    button.addEventListener("click", (event) => {
      event.stopPropagation();
      setOpen(root.dataset.open !== "true");
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("click", (event) => {
      if (!root.contains(event.target)) setOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
  }
</script>
