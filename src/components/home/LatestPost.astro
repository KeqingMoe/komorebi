---
import { formatDate, getPostUrl, type PostEntry } from "../../lib/content";
import ReadingTime from "../widgets/ReadingTime.astro";

interface Props {
  post: PostEntry;
}

const { post } = Astro.props as Props;
---

<a
  href={getPostUrl(post.id)}
  class="group grid gap-3 py-5 transition sm:grid-cols-[10rem_minmax(0,1fr)_auto] sm:items-start sm:gap-6"
>
  <div class="text-sm text-zinc-500">
    <time class="block font-medium text-zinc-700">
      {formatDate(post.data.pubDate)}
    </time>
  </div>

  <div class="min-w-0">
    <h3
      class="text-2xl font-semibold tracking-tight text-zinc-950 transition group-hover:text-rose-500"
    >
      {post.data.title}
    </h3>
    <p class="mt-2 max-w-2xl text-base leading-7 text-zinc-600">
      {post.data.description}
    </p>
  </div>

  <div class="flex shrink-0 items-center gap-3 text-sm text-zinc-500 sm:pt-1">
    <ReadingTime milliseconds={post.readingStats.time} />
    <span
      class="font-semibold transition duration-200 group-hover:translate-x-1 group-hover:text-rose-500"
    >
      →
    </span>
  </div>
</a>
