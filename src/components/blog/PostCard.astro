---
import { formatDate, getPostUrl, type PostEntry } from "../../lib/content";
import ReadingTime from "../widgets/ReadingTime.astro";
import WordsCount from "../widgets/WordsCount.astro";

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { words, time: milliseconds } = post.readingStats;
const publishedLabel = formatDate(post.data.pubDate);
const updatedLabel = post.data.updatedDate ? formatDate(post.data.updatedDate) : undefined;
---

<a href={getPostUrl(post.id)} class="group block">
  <article class="-mx-4 rounded-[22px] px-4 py-6 transition duration-200 hover:bg-white/38 sm:py-7">
    <div class="grid gap-4 md:grid-cols-[10rem_minmax(0,1fr)] md:gap-7">
      <div class="space-y-2.5 text-sm text-zinc-400 md:pt-0.5">
        <time class="block font-medium text-zinc-600">{publishedLabel}</time>

        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <WordsCount {words} />
          <span class="text-zinc-300">·</span>
          <ReadingTime {milliseconds} />
        </div>

        {
          updatedLabel && (
            <p class="text-xs text-zinc-400">
              更新于 {updatedLabel}
            </p>
          )
        }
      </div>

      <div class="min-w-0">
        <h2 class="text-[1.85rem] font-semibold tracking-tight text-zinc-950 transition group-hover:text-rose-500 sm:text-[2rem]">
          {post.data.title}
        </h2>

        <p class="mt-3 max-w-2xl text-base leading-7 text-zinc-600">
          {post.data.description}
        </p>
ƒ
        <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-zinc-500 transition duration-200 group-hover:text-rose-500">
          阅读全文
          <span class="transition duration-200 group-hover:translate-x-1">→</span>
        </div>
      </div>
    </div>
  </article>
</a>
