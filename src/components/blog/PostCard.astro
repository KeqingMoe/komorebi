---
import { getPostUrl, type PostEntry } from "../../lib/content";
import ReadingTime from "../widgets/ReadingTime.astro";
import WordsCount from "../widgets/WordsCount.astro";

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { words, time: milliseconds } = post.readingStats;
---

<a
  class="group"
  w-full
  flex="~ col"
  transition-all
  px-5
  py-2.5
  max-sm:px-4
  sm:py-5
  href={getPostUrl(post.id)}
>
  <article flex="~ col" h-full>
    <div flex items-start justify-between gap-3>
      <div>
        <h2 text-xl font-semibold group-hover:text-primary transition-colors>
          {post.data.title}
        </h2>
        <p mt-2 text="sm base-content/70" leading-relaxed line-clamp="3">
          {post.data.description}
        </p>
      </div>
      <time
        shrink-0
        rounded-xl
        bg="primary/30"
        text="primary xs"
        font-medium
        px-3
        py-1
      >
        {post.data.pubDate.toLocaleDateString("zh-CN")}
      </time>
    </div>
    <div mt-6 flex items-center justify-between text="sm base-content/70">
      <span flex items-center gap-2>
        <WordsCount {words} />
      </span>
      <span flex items-center gap-2>
        <ReadingTime {milliseconds} />
      </span>
    </div>
  </article>
</a>
