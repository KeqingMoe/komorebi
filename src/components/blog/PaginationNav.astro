---
interface Props {
  prev: string | undefined;
  next: string | undefined;
  first: string | undefined;
  last: string | undefined;
  total: number;
  current: number;
}

const { first, prev, next, last, total, current } = Astro.props;
---

<nav aria-label="分页导航">
  {prev ? <a href={prev}>上一页</a> : <span>上一页</span>}

  {
    first && first != prev && (
      <a href={first} title="首页">1</a>
    )
  }

  {
    current - 2 > 1 && (
      <span>…</span>
    )
  }

  {
    prev && (
      <a href={prev} title="上一页">{current - 1}</a>
    )
  }

  <span aria-current="page">{current}</span>

  {
    next && (
      <a href={next} title="下一页">{current + 1}</a>
    )
  }

  {
    current + 2 < total && (
      <span>…</span>
    )
  }

  {
    last && last != next && (
      <a href={last} title="末页">{total}</a>
    )
  }

  {next ? <a href={next}>下一页</a> : <span>下一页</span>}
</nav>
