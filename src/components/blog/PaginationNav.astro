---
interface Props {
  prev: string | undefined;
  next: string | undefined;
  first: string | undefined;
  last: string | undefined;
  total: number;
  current: number;
  posts: number;
}

const { first, prev, next, last, total, current, posts } = Astro.props;
---

<div flex="~ col sm:row" sm:items-center sm:justify-between gap-4>
  <div flex items-center gap-3 text="base base-content/70">
    共 {posts} 篇文章
  </div>
  <nav flex="~ wrap" items-center gap-2 aria-label="分页导航">
    {
      first && first != prev && (
        <a
          href={first}
          class="pagination-btn"
          title="首页"
          transition:name={`pagination-btn-1`}
        >
          1
        </a>
      )
    }

    {current - 2 > 1 && <span class="pagination-dots">···</span>}

    {
      prev && (
        <a
          href={prev}
          class="pagination-btn"
          title="上一页"
          transition:name={`pagination-btn-${current - 1}`}
        >
          {current - 1}
        </a>
      )
    }

    <span
      class="pagination-current"
      transition:name={`pagination-btn-${current}`}
    >
      {current}
    </span>

    {
      next && (
        <a
          href={next}
          class="pagination-btn"
          title="下一页"
          transition:name={`pagination-btn-${current + 1}`}
        >
          {current + 1}
        </a>
      )
    }

    {current + 2 < total && <span class="pagination-dots">···</span>}

    {
      last && last != next && (
        <a
          href={last}
          class="pagination-btn"
          title="末页"
          transition:name={`pagination-btn-${total}`}
        >
          {total}
        </a>
      )
    }
  </nav>
</div>

<style>
  .pagination-btn,
  .pagination-current,
  .pagination-dots {
    @apply w-10 h-10 flex items-center justify-center rounded-full;
  }

  .pagination-btn {
    @apply bg-transparent text-base-content/70 border border-base-content/10 
           transition-all duration-200;
  }
  .pagination-btn:hover {
    @apply bg-base-100 text-base-content border-base-content/30 shadow-sm;
  }

  .pagination-current {
    @apply text-base-content font-bold shadow-lg scale-110 border border-base-content/30;
  }

  .pagination-dots {
    @apply text-base-content/40 select-none;
  }
</style>
