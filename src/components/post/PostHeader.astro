---
import type { ReadTimeResults } from "reading-time";
import { formatDate } from "../../lib/content";
import WordsCount from "../widgets/WordsCount.astro";
import ReadingTime from "../widgets/ReadingTime.astro";

interface Props {
  title: string;
  description?: string | undefined;
  pubDate?: Date | undefined;
  updatedDate?: Date | undefined;
  draft?: boolean | undefined;
  readingStats?: ReadTimeResults | undefined;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  draft = false,
  readingStats,
} = Astro.props;

const publishedLabel = pubDate ? formatDate(pubDate) : undefined;
const updatedLabel = updatedDate ? formatDate(updatedDate) : undefined;
---

<header class="border-b border-zinc-200/80 pb-10">
  {
    draft && (
      <p class="mb-6 inline-flex rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-700">
        草稿 · 仅开发模式可见
      </p>
    )
  }

  <div class="overflow-x-auto sm:overflow-visible">
    <div class="post-meta">
      {
        publishedLabel && (
          <span class="post-meta__item">
            <span class="post-meta__label">发布于</span>
            <time class="post-meta__value">{publishedLabel}</time>
          </span>
        )
      }
      {
        updatedLabel && (
          <span class="post-meta__item">
            <span class="post-meta__label">更新于</span>
            <time class="post-meta__value">{updatedLabel}</time>
          </span>
        )
      }
      {
        readingStats && (
          <>
            <span class="post-meta__item post-meta__item--emphasis">
              <WordsCount words={Math.round(readingStats.words)} />
            </span>
            <span class="post-meta__item">
              <span class="post-meta__label">阅读约</span>
              <span class="post-meta__value"><ReadingTime milliseconds={readingStats.time} /></span>
            </span>
          </>
        )
      }
    </div>
  </div>

  <div class="mt-4 space-y-3 sm:mt-6 sm:space-y-4">
    <h1 class="max-w-4xl text-4xl font-black tracking-tight text-zinc-950 sm:text-5xl lg:text-[3.75rem] lg:leading-[1.1]">
      {title}
    </h1>

    {
      description && (
        <p class="max-w-3xl text-base leading-7 text-zinc-600 sm:text-xl sm:leading-8">
          {description}
        </p>
      )
    }
  </div>
</header>

<style>
  .post-meta {
    display: flex;
    min-width: max-content;
    align-items: center;
    white-space: nowrap;
    font-size: 0.75rem;
    line-height: 1.25rem;
    color: rgb(113 113 122 / 0.9);
  }

  .post-meta__item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .post-meta__item + .post-meta__item::before {
    content: "·";
    margin-inline: 0.375rem;
    color: rgb(212 212 216);
  }

  .post-meta__label {
    color: rgb(161 161 170);
  }

  .post-meta__value {
    font-weight: 500;
    color: rgb(39 39 42);
  }

  .post-meta__item--emphasis {
    font-weight: 500;
    color: rgb(39 39 42);
  }

  @media (min-width: 640px) {
    .post-meta {
      min-width: 0;
      flex-wrap: wrap;
      row-gap: 0.25rem;
      white-space: normal;
      font-size: 0.875rem;
      line-height: 1.5rem;
    }

    .post-meta__item {
      align-items: center;
      gap: 0.375rem;
    }

    .post-meta__item + .post-meta__item::before {
      margin-inline: 0.75rem;
    }

    .post-meta__label {
      color: rgb(113 113 122 / 0.9);
    }

    .post-meta__item--emphasis {
      font-weight: 400;
      color: rgb(113 113 122 / 0.9);
    }
  }
</style>
