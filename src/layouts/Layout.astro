---
import Footer from "../components/layout/Footer.astro";
import MaskLayer from "../components/layout/MaskLayer.astro";
import NavToggle from "../components/layout/Nav/NavToggle.astro";
import SideNav from "../components/layout/Nav/SideNav.astro";
import Base from "./Base.astro";

interface Props {
  title: string | undefined;
}

const { title } = Astro.props;
---

<Base {title}>
  <div flex="~ row" justify-between min-h-100dvh bg-base-200>
    <SideNav />
    <MaskLayer />
    <main mx-auto w-100% md:w-76ch p-4>
      <slot />
      <Footer />
    </main>
    <div fixed right-4 bottom-4 z-100 md:hidden>
      <NavToggle />
    </div>
  </div>
</Base>
