---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "木漏れ日 Blog" } = Astro.props;
---

<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {
      Astro.site && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title="木漏れ日"
          href={new URL("rss.xml", Astro.site)}
        />
      )
    }
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <h1><a href="/">木漏れ日</a></h1>
      <nav aria-label="主导航">
        <a href="/">首页</a>
        <a href="/archive">归档</a>
        <a href="/about">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
