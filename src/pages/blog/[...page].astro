---
import type { GetStaticPaths } from "astro";
import { getSortedPosts } from "../../lib/content";
import Layout from "../../layouts/Layout.astro";
import PaginationNav from "../../components/blog/PaginationNav.astro";
import PostCard from "../../components/blog/PostCard.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getSortedPosts();
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;

const { url, size, lastPage: total, currentPage: current } = page;
const props = {
  ...url,
  total,
  current,
};
---

<Layout title="文章列表">
  <div space-y-4 min-h-100dvh>
    <div flex="~ row" justify-between>
      <span>
        第 {current} 页 - 每页 {size} 篇，共 {total} 篇
      </span>
      <a hover:text-primary transition-colors duration-200 href="/archive"
        >查看所有文章 →</a
      >
    </div>

    <div flex="~ col" gap-y-4 text-start>
      {posts.map((post) => <PostCard {post} />)}
    </div>

    <div sticky bottom-8 pt-4 flex justify-center>
      <PaginationNav {...props} />
    </div>
  </div>
</Layout>
