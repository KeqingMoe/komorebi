---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import { render } from "astro:content";
import { getSortedPosts } from "../../lib/content";
import PostHeader from "../../components/post/PostHeader.astro";
import AdjacentNav from "../../components/post/AdjacentNav.astro";

export const getStaticPaths = (async () => {
  const posts = await getSortedPosts();
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      prev: posts[i - 1],
      post,
      next: posts[i + 1],
    },
  }));
}) satisfies GetStaticPaths;

const { prev, post, next } = Astro.props;
const { title, description, pubDate, updatedDate, draft } = post.data;
const { readingStats } = post;
const { Content } = await render(post);
---

<Layout title={title}>
  <article>
    <PostHeader
      {...{ title, description, pubDate, updatedDate, draft, readingStats }}
    />
    <Content />
  </article>

  <AdjacentNav {prev} {next} />
</Layout>
