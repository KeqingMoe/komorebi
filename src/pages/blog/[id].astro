---
import type { GetStaticPaths } from "astro";
import Base from "../../layouts/Base.astro";
import { render } from "astro:content";
import { getSortedPosts, getPostUrl } from "../../lib/content";
import ReadingTime from "../../components/widgets/ReadingTime.astro";
import WordsCount from "../../components/widgets/WordsCount.astro";

export const getStaticPaths = (async () => {
  const posts = await getSortedPosts();
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      prevPost: posts[i - 1],
      post,
      nextPost: posts[i + 1],
    },
  }));
}) satisfies GetStaticPaths;

const { prevPost, post, nextPost } = Astro.props;
const { title, description, pubDate, updatedDate, draft } = post.data;
const { words, time: milliseconds } = post.readingStats;
const { Content } = await render(post);
---

<Base title={title}>
  <article mt-6>
    <section
      border="~ base-content/5"
      bg="base-200/40"
      p="6 md:8 lg:12"
      rounded-2xl
      shadow-sm
      text-base
    >
      <div flex="~ wrap" gap-x-4 gap-y-2 text="base-content/70">
        <div flex items-center gap-1>
          <div i-mdi:calendar-month></div>
          <time>{pubDate.toLocaleDateString("zh-CN")}</time>
        </div>

        {
          updatedDate && (
            <div flex items-center gap-1>
              <div i-mdi:calendar-edit />
              <time>{updatedDate.toLocaleDateString("zh-CN")}</time>
            </div>
          )
        }

        <div flex items-center gap-1>
          <WordsCount {words} />
        </div>

        <div flex items-center gap-1>
          <ReadingTime {milliseconds} />
        </div>

        {
          draft && (
            <div flex items-center gap-1 text-red font-bold>
              这篇文章还是草稿，仅开发模式可见。
            </div>
          )
        }
      </div>

      <h1 mt="3" text="2xl sm:3xl" font-medium sm:mb-2>{title}</h1>
      <p mt-3 italic text="base-content/70">{description}</p>

      <div py-1></div>

      <div prose="~ dark:invert" max-w-full>
        <Content />
      </div>
    </section>
  </article>

  <div>
    <nav class="adjacent">
      <div class="prev">
        {
          prevPost && (
            <a href={getPostUrl(prevPost.id)}>
              <span>← 上一篇</span>
              <strong>{prevPost.data.title}</strong>
            </a>
          )
        }
      </div>
      <div class="next">
        {
          nextPost && (
            <a href={getPostUrl(nextPost.id)}>
              <span>下一篇 →</span>
              <strong>{nextPost.data.title}</strong>
            </a>
          )
        }
      </div>
    </nav>
  </div>
</Base>
