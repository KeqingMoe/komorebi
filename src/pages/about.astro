---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { computeReadingTime } from "../lib/content";
import PostHeader from "../components/post/PostHeader.astro";
import { render } from "astro:content";

const about = await getEntry("special", "about");
if (!about) {
  return Astro.redirect("/404");
}
const { title, pubDate, updatedDate } = about.data;
const readingStats = computeReadingTime(about?.body ?? "");
const { Content } = await render(about);
---

<Layout title="关于">
  <article>
    <PostHeader {...{ title, pubDate, updatedDate, readingStats }} />
    <Content />
  </article>
</Layout>
