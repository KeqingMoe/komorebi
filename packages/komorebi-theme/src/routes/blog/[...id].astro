---
import { render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import type { GiscusOptions } from '../../options';
import PostContentLayout from '../../runtime/components/post/PostContentLayout.astro';
import GiscusComments from '../../runtime/components/widgets/GiscusComments.astro';
import { themeConfig } from '../../runtime/config';
import Layout from '../../runtime/layouts/Layout.astro';
import { getSortedPosts } from '../../runtime/lib/content';

export const getStaticPaths = (async () => {
  const posts = await getSortedPosts();
  return posts.map((post, i) => ({
    params: { id: post.id },
    props: {
      prev: posts[i - 1],
      post,
      next: posts[i + 1],
    },
  }));
}) satisfies GetStaticPaths;

const { prev, post, next } = Astro.props;
const { title, description, pubDate, updatedDate, draft } = post.data;
const { readingStats } = post;
const { Content, headings } = await render(post);

const comments = themeConfig.comments;

const processComments = (comments: GiscusOptions) => {
  const { theme, ...rest } = comments;
  const giscusTheme = theme
    ? {
        theme: typeof theme === 'object' ? theme.preset : theme,
      }
    : {};
  return { ...rest, ...giscusTheme };
};
---

<Layout title={title}>
  <PostContentLayout
    {...{
      title,
      description,
      pubDate,
      updatedDate,
      draft,
      readingStats,
      headings,
      prev,
      next,
    }}
  >
    <Content />
    {
      comments && (
        <>
          <hr />
          <GiscusComments {...processComments(comments)} />
        </>
      )
    }
  </PostContentLayout>
</Layout>
