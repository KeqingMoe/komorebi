---
import ArchiveTimeline from '../runtime/components/archive/ArchiveTimeline.astro';
import PageIntro from '../runtime/components/common/PageIntro.astro';
import Layout from '../runtime/layouts/Layout.astro';
import { buildArchiveYears } from '../runtime/lib/archive';
import { getSortedPosts } from '../runtime/lib/content';

const posts = await getSortedPosts();
const archiveYears = buildArchiveYears(posts);
---

<Layout title="归档">
  <PageIntro
    eyebrow="Archive"
    title="文章归档"
    description="按年、月、日回看所有文章，适合整理长期写作的时间线。"
    titleClass="text-4xl font-black tracking-tight text-zinc-950 sm:text-5xl"
  />

  <ArchiveTimeline years={archiveYears} />
</Layout>
