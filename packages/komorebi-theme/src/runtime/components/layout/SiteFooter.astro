---
import { siteLabels } from "../../lib/site";

interface Props {
  siteTitle: string;
  repositoryUrl?: string | undefined;
  rssHref?: string | undefined;
}

const { siteTitle, repositoryUrl, rssHref = "/rss.xml" } = Astro.props as Props;
---

<footer
  class="mx-auto w-full max-w-7xl px-6 pb-10 text-sm text-zinc-500 sm:px-8 lg:px-10 lg:pb-14"
>
  <div class="border-t border-zinc-200/80 pt-6">
    <div
      class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between"
    >
      {
        repositoryUrl ? (
          <a href={repositoryUrl} class="transition hover:text-zinc-950">
            {siteTitle}
          </a>
        ) : (
          <span>{siteTitle}</span>
        )
      }
      <a href={rssHref} class="transition hover:text-zinc-950">{siteLabels.footerRss}</a>
    </div>
  </div>
</footer>
