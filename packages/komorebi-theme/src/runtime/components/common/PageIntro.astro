---
interface Props {
  eyebrow?: string | undefined;
  title: string;
  description?: string | undefined;
  containerClass?: string | undefined;
  titleClass?: string | undefined;
}

const {
  eyebrow,
  title,
  description,
  containerClass = 'max-w-4xl',
  titleClass = 'text-4xl font-black tracking-tight text-zinc-950 sm:text-[3.5rem]',
} = Astro.props as Props;

const hasActions = Astro.slots.has('actions');
const hasMeta = Astro.slots.has('meta');
---

<section class={containerClass}>
  {
    eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-zinc-500">
        {eyebrow}
      </p>
    )
  }

  <div
    class:list={[
      "mt-4",
      hasActions && "flex flex-wrap items-start justify-between gap-4",
    ]}
  >
    <div>
      <h1 class={titleClass}>{title}</h1>
      {
        description && (
          <p class="mt-4 max-w-3xl text-base leading-8 text-zinc-600 sm:text-lg">
            {description}
          </p>
        )
      }
    </div>

    {
      hasActions && (
        <div class="pt-1">
          <slot name="actions" />
        </div>
      )
    }
  </div>

  {
    hasMeta && (
      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-500">
        <slot name="meta" />
      </div>
    )
  }
</section>
